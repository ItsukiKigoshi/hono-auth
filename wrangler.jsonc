{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hono-auth",
  "compatibility_date": "2026-03-24",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "pages_build_output_dir": "./dist", 
  "d1_databases": [
    {
      "binding": "hono_auth_db",
